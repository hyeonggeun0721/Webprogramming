<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>주문조회 - ECO-LIFE Mall</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <style>
    :root {
      --primary-emerald: #064E3B;
      --primary-hover: #059669;
      --accent-gold: #FACC15;
      --bg-cream: #F8FAF9;
      --text-slate: #334155;
      --text-gray: #64748b;
      --border-color: #E2E8F0;
      --white: #ffffff;
      --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
      --shadow-md: 0 10px 25px rgba(0,0,0,0.05);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Noto Sans KR', sans-serif; }

    body { background-color: var(--bg-cream); color: var(--text-slate); display: flex; flex-direction: column; min-height: 100vh; line-height: 1.6; }

    .top-bar { display: flex; justify-content: flex-end; align-items: center; padding: 10px 40px; background-color: var(--primary-emerald); color: white; font-size: 0.9em; }
    .top-bar span { margin-right: 15px; }
    .top-bar a { color: white; text-decoration: none; padding: 5px 12px; border-radius: 4px; margin-left: 8px; transition: 0.2s; }
    .top-bar .btn-login { background-color: var(--accent-gold); color: var(--primary-emerald); font-weight: 700; }
    .top-bar .btn-logout { background-color: #ef4444; }

    header.main-header { background-color: var(--white); padding: 20px 40px; box-shadow: var(--shadow-sm); position: sticky; top: 0; z-index: 1000; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; border-bottom: 1px solid var(--border-color); }
    .logo { font-family: 'Poppins', sans-serif; font-size: 24px; font-weight: 700; color: var(--primary-emerald); text-decoration: none; display: flex; align-items: center; gap: 10px; }
    
    nav { display: flex; gap: 20px; flex-wrap: wrap; }
    nav a { text-decoration: none; color: var(--text-slate); font-weight: 500; padding: 8px 12px; border-radius: 6px; transition: 0.2s; white-space: nowrap; }
    nav a:hover { background-color: #f1f5f9; color: var(--primary-emerald); }
    .admin-link { color: #ef4444 !important; font-weight: 700 !important; }

    .page-header { background: linear-gradient(135deg, rgba(6, 78, 59, 0.05) 0%, transparent 100%); padding: 50px 20px; text-align: center; border-bottom: 1px solid var(--border-color); }
    .page-header h1 { font-family: 'Poppins', sans-serif; font-size: 32px; color: var(--primary-emerald); margin-bottom: 10px; }
    .page-header p { color: var(--text-gray); }

    main { flex: 1; width: 100%; max-width: 900px; margin: 40px auto 80px; padding: 0 20px; }

    .order-group { background: var(--white); border: 1px solid var(--border-color); margin-bottom: 25px; border-radius: 12px; box-shadow: var(--shadow-sm); overflow: hidden; }
    
    .order-group-header { 
        padding: 16px 20px; 
        background-color: #f8fafc; 
        border-bottom: 1px solid var(--border-color); 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
    }
    .order-date { font-weight: 700; font-size: 16px; color: var(--text-slate); }
    .order-detail-link { color: var(--text-gray); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 5px; }
    .order-detail-link:hover { text-decoration: underline; }

    .order-item { padding: 24px 20px; border-bottom: 1px solid var(--border-color); }
    .order-item:last-child { border-bottom: none; }

    .order-status { font-weight: 700; font-size: 16px; margin-bottom: 16px; color: var(--text-slate); }
    .order-status.highlight { color: #3b82f6; } 

    .order-content { display: flex; gap: 20px; margin-bottom: 20px; }
    .product-img { 
        width: 80px; 
        height: 100px; 
        object-fit: cover; 
        background-color: #f8f8f8; 
        border-radius: 6px;
        flex-shrink: 0;
        border: 1px solid var(--border-color);
    }
    
    .order-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
    .brand-name { font-size: 12px; font-weight: 700; color: #555; margin-bottom: 6px; }
    .product-name { font-size: 15px; font-weight: 500; color: var(--text-slate); margin-bottom: 6px; line-height: 1.4; }
    .product-meta { font-size: 13px; color: var(--text-gray); margin-bottom: 10px; }
    .product-price { font-size: 15px; font-weight: 700; color: var(--text-slate); }

    .order-actions { display: flex; gap: 10px; }
    .btn-action { 
        flex: 1; 
        padding: 13px 0; 
        text-align: center; 
        border: 1px solid var(--border-color); 
        background: var(--white); 
        font-size: 13px; 
        font-weight: 500; 
        color: var(--text-slate); 
        cursor: pointer; 
        text-decoration: none;
        border-radius: 6px;
        transition: 0.2s;
        display: block;
    }
    .btn-action:hover { background: #f8fafc; border-color: #cbd5e1; }

    .empty-state { text-align: center; padding: 80px 20px; background: var(--white); border-radius: 12px; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color); }
    .empty-state p { color: var(--text-gray); margin-bottom: 20px; font-size: 15px; }

    footer { text-align: center; padding: 40px 20px; background: var(--primary-emerald); color: rgba(255,255,255,0.6); font-size: 14px; margin-top: auto; }

    /* 모달 스타일 추가 */
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; }
    .modal-content { background: #fff; width: 90%; max-width: 400px; border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-md); animation: fadeIn 0.2s ease-out; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 18px 20px; background: #f8fafc; border-bottom: 1px solid var(--border-color); }
    .modal-header h3 { font-size: 16px; margin: 0; color: var(--text-main); }
    .close-btn { background: none; border: none; font-size: 20px; cursor: pointer; color: var(--text-gray); }
    .modal-body { padding: 25px 20px; font-size: 14px; }
    .modal-info-box { background: #f1f5f9; padding: 15px; border-radius: 8px; margin-bottom: 20px; }
    .modal-info-box p { margin: 5px 0; color: var(--text-slate); }
    .tracking-history { list-style: none; padding: 0; margin: 0; color: var(--text-slate); }
    .tracking-history li { position: relative; padding-left: 15px; margin-bottom: 12px; font-size: 13.5px; }
    .tracking-history li::before { content: ''; position: absolute; left: 0; top: 6px; width: 6px; height: 6px; background: #cbd5e1; border-radius: 50%; }
    .tracking-history li:first-child::before { background: var(--primary-emerald); }
    .tracking-history li span { font-weight: 600; color: var(--primary-emerald); margin-right: 5px; }
    .tracking-history li:not(:first-child) span { color: var(--text-gray); }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 1024px) {
      .top-bar { padding: 10px 20px; }
      header.main-header { padding: 15px 20px; flex-direction: column; align-items: center; gap: 15px; }
      nav { justify-content: center; width: 100%; gap: 10px; }
      nav a { font-size: 13px; padding: 6px 8px; }
    }

    @media (max-width: 640px) {
      nav { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; text-align: center; }
      nav a { font-size: 12px; padding: 6px 2px; }
      .order-content { gap: 15px; }
      .product-img { width: 70px; height: 88px; }
      .product-name { font-size: 14px; }
    }
  </style>
</head>
<body>

  <div class="top-bar">
    <% if (!user) { %>
        <a href="/stud6/user/login" class="btn-login">로그인</a>
        <a href="/stud6/user/register" class="btn-login">회원가입</a>
    <% } else { %>
        <span><strong><%= user.name %></strong>님 환영합니다!</span>
        <a href="/stud6/user/logout" class="btn-logout">로그아웃</a>
    <% } %>
  </div>

  <header class="main-header">
    <a href="/stud6/" class="logo"><i class="fa-solid fa-basket-shopping"></i> ECO-LIFE</a>
    <nav>
      <a href="/stud6/">홈</a>
      <a href="/stud6/products">상품목록</a>
      <a href="/stud6/cart">장바구니</a>
      <a href="/stud6/board">고객센터</a>
      <a href="/stud6/notice">공지사항</a>
      <a href="/stud6/user/mypage">마이페이지</a>
      <a href="/stud6/user/wishlist">위시리스트</a>
      <a href="/stud6/user/orders" style="color: var(--primary-emerald); font-weight: 700;">주문조회</a>
      <% if (typeof user !== 'undefined' && user && user.username === 'admin') { %>
        <a href="/stud6/admin" class="admin-link">[관리자 모드]</a>
      <% } %>
    </nav>
  </header>

  <div class="page-header">
    <h1><i class="fa-solid fa-box-open"></i> 주문 및 배송조회</h1>
    <p>고객님께서 주문하신 소중한 상품의 배송 상태를 확인하세요.</p>
  </div>

  <main>
    <% if (!orders || orders.length === 0) { %>
        <div class="empty-state">
            <i class="fa-solid fa-receipt" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 15px;"></i>
            <p>주문 내역이 없습니다.</p>
            <a href="/stud6/products" class="btn-action" style="display:inline-block; width:160px; padding: 12px 0; font-weight: 700; background: var(--primary-emerald); color: white; border: none; margin: 0 auto;">쇼핑하러 가기</a>
        </div>
    <% } else { %>
        <% 
            const groupedOrders = {};
            orders.forEach(order => {
                const key = order.order_date;
                if (!groupedOrders[key]) {
                    groupedOrders[key] = {
                        date: order.order_date,
                        items: []
                    };
                }
                groupedOrders[key].items.push(order);
            });
            
            const groupList = Object.values(groupedOrders).sort((a, b) => new Date(b.date) - new Date(a.date));
            const days = ['일', '월', '화', '수', '목', '금', '토'];
        %>

        <% groupList.forEach(group => { %>
            <% 
                const d = new Date(group.date);
                const yy = String(d.getFullYear()).slice(-2);
                const mm = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                const dayStr = days[d.getDay()];
                const formattedDate = `${yy}.${mm}.${dd}(${dayStr})`;
            %>

            <div class="order-group">
                <div class="order-group-header">
                    <span class="order-date"><%= formattedDate %></span>
                    <a href="/stud6/user/order_detail?date=<%= group.date %>" class="order-detail-link">주문 상세 <i class="fa-solid fa-chevron-right" style="font-size: 10px;"></i></a>
                </div>

                <% group.items.forEach(item => { %>
                    <div class="order-item">
                        <div class="order-status <%= (item.status === '배송완료' || item.status === '구매 확정') ? 'highlight' : '' %>">
                            <%= item.status || '결제완료' %>
                        </div>
                        
                        <div class="order-content">
                            <img src="../images/<%= item.image_url || 'default.png' %>" class="product-img" alt="<%= item.product_name %>">
                            
                            <div class="order-info">
                                <div class="brand-name">ECO-LIFE</div>
                                <div class="product-name"><%= item.product_name %></div>
                                <div class="product-meta">단일옵션 / <%= item.quantity || 1 %>개</div>
                                <div class="product-price"><%= Number(item.price).toLocaleString() %>원</div>
                            </div>
                        </div>

                        <div class="order-actions">
                            <a href="#" class="btn-action" onclick="openTrackingModal(event, '<%= item.status || '결제완료' %>')">배송 조회</a>
                            <a href="/stud6/products" class="btn-action">재구매</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% }) %>
    <% } %>
  </main>

  <footer>
    <p>&copy; 2026 Premium ECO-LIFE Mall. All rights reserved.</p>
  </footer>

  <div id="trackingModal" class="modal-overlay" onclick="closeTrackingModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h3><i class="fa-solid fa-truck"></i> 배송 현황 조회</h3>
        <button class="close-btn" onclick="closeTrackingModal(event)"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="modal-info-box">
          <p><strong>택배사:</strong> ECO 로지스틱스</p>
          <p><strong>운송장 번호:</strong> 5832-1943-2281</p>
        </div>
        <ul class="tracking-history" id="trackingHistoryList">
        </ul>
      </div>
    </div>
  </div>

  <script>
    function openTrackingModal(e, status) {
        e.preventDefault();
        
        const historyList = document.getElementById('trackingHistoryList');
        let html = '';

        if (status === '결제완료' || status === '배송준비') {
            html = `
                <li><span>[상품준비중]</span> 판매자가 상품을 준비하고 있습니다.</li>
                <li><span>[결제완료]</span> 입금이 확인되었습니다.</li>
            `;
        } else if (status === '배송중') {
            html = `
                <li><span>[배송중]</span> 배송 기사님이 배달을 시작했습니다.</li>
                <li><span>[간선하차]</span> 지역 터미널에 도착했습니다.</li>
                <li><span>[간선상차]</span> 허브 터미널에서 출발했습니다.</li>
                <li><span>[집화처리]</span> 택배사에서 상품을 인수했습니다.</li>
            `;
        } else {
            html = `
                <li><span>[배송완료]</span> 고객님께 상품이 전달되었습니다.</li>
                <li><span>[배송중]</span> 배송 기사님이 배달을 시작했습니다.</li>
                <li><span>[간선하차]</span> 지역 터미널에 도착했습니다.</li>
                <li><span>[집화처리]</span> 택배사에서 상품을 인수했습니다.</li>
            `;
        }

        historyList.innerHTML = html;
        document.getElementById('trackingModal').style.display = 'flex';
    }

    function closeTrackingModal(e) {
        if(e) e.preventDefault();
        document.getElementById('trackingModal').style.display = 'none';
    }
  </script>
</body>
</html>